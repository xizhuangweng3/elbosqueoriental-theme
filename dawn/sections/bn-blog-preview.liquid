{%- comment -%}
  bn-blog-preview.liquid
  Homepage blog preview — 3 manually-selected article blocks.
  Each block lets you pick any article from any blog in the Theme Editor.
  Figma: beige #F9ECDD bg, 3-column grid, image 245px + date + title + excerpt.
{%- endcomment -%}

<style>
  #shopify-section-{{ section.id }} {
    background-color: #F9ECDD;
    padding: 56px 0;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} { padding: 40px 0; }
  }

  /* ── Container ── */
  #shopify-section-{{ section.id }} .bn-blog__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 30px;
  }

  /* ── Header row ── */
  #shopify-section-{{ section.id }} .bn-blog__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 32px;
    gap: 1.6rem;
  }

  #shopify-section-{{ section.id }} .bn-blog__heading {
    font-family: var(--font-heading-family);
    font-size: 3.6rem;
    font-weight: 700;
    color: #143007;
    margin: 0;
    line-height: 84%;
    letter-spacing: -0.02em;
  }

  #shopify-section-{{ section.id }} .bn-blog__see-all {
    font-family: var(--font-body-family);
    font-size: 1.4rem;
    color: #143007;
    text-decoration: underline;
    text-underline-offset: 3px;
    white-space: nowrap;
    flex-shrink: 0;
    transition: opacity 0.2s ease;
  }

  #shopify-section-{{ section.id }} .bn-blog__see-all:hover { opacity: 0.65; }

  /* ── 3-column grid ── */
  #shopify-section-{{ section.id }} .bn-blog__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .bn-blog__grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  @media screen and (min-width: 600px) and (max-width: 749px) {
    #shopify-section-{{ section.id }} .bn-blog__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ── Card ── */
  #shopify-section-{{ section.id }} .bn-blog__card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    transition: transform 0.3s ease;
  }

  #shopify-section-{{ section.id }} .bn-blog__card:hover {
    transform: translateY(-4px);
  }

  /* ── Image ── */
  #shopify-section-{{ section.id }} .bn-blog__media {
    position: relative;
    width: 100%;
    padding-top: 66.6%;
    overflow: hidden;
    border-radius: 4px 4px 0 0;
    background: #d4c5b0;
  }

  #shopify-section-{{ section.id }} .bn-blog__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.4s ease;
  }

  #shopify-section-{{ section.id }} .bn-blog__card:hover .bn-blog__img {
    transform: scale(1.04);
  }

  /* ── Card body ── */
  #shopify-section-{{ section.id }} .bn-blog__body {
    padding: 16px 0 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  #shopify-section-{{ section.id }} .bn-blog__date {
    font-family: var(--font-body-family);
    font-size: 1.3rem;
    color: #6C6C6C;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .bn-blog__title {
    font-family: var(--font-heading-family);
    font-size: 1.8rem;
    font-weight: 700;
    color: #143007;
    margin: 0;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }

  #shopify-section-{{ section.id }} .bn-blog__excerpt {
    font-family: var(--font-body-family);
    font-size: 1.5rem;
    color: #121212;
    line-height: 1.6;
    margin: 0;
    opacity: 0.75;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Placeholder card ── */
  #shopify-section-{{ section.id }} .bn-blog__placeholder {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  #shopify-section-{{ section.id }} .bn-blog__placeholder-img {
    width: 100%;
    padding-top: 66.6%;
    background: #d4c5b0;
    border-radius: 4px 4px 0 0;
  }

  #shopify-section-{{ section.id }} .bn-blog__placeholder-text {
    font-family: var(--font-body-family);
    font-size: 1.4rem;
    color: #143007;
    opacity: 0.5;
    padding-top: 8px;
  }
</style>

<div>
  <div class="bn-blog__inner">

    {%- if section.settings.heading != blank or section.settings.see_all_url != blank -%}
      <div class="bn-blog__head">
        {%- if section.settings.heading != blank -%}
          <h2 class="bn-blog__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.see_all_label != blank and section.settings.see_all_url != blank -%}
          <a href="{{ section.settings.see_all_url }}" class="bn-blog__see-all">
            {{ section.settings.see_all_label }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    <ul class="bn-blog__grid" role="list">
      {%- for block in section.blocks -%}
        {%- assign article = block.settings.article -%}
        {%- assign img = block.settings.image_override | default: article.image -%}
        <li {{ block.shopify_attributes }}>
          {%- if article != blank -%}
            <a href="{{ article.url }}" class="bn-blog__card">
              <div class="bn-blog__media">
                {%- if img != blank -%}
                  {{
                    img
                    | image_url: width: 800
                    | image_tag:
                      loading: 'lazy',
                      widths: '400, 600, 800',
                      alt: img.alt | default: article.title,
                      class: 'bn-blog__img'
                  }}
                {%- else -%}
                  {{ 'lifestyle-1' | placeholder_svg_tag: 'bn-blog__img' }}
                {%- endif -%}
              </div>
              <div class="bn-blog__body">
                <p class="bn-blog__date">{{ article.published_at | date: '%d %B %Y' }}</p>
                <h3 class="bn-blog__title">{{ article.title }}</h3>
                {%- if article.excerpt_or_content != blank -%}
                  <p class="bn-blog__excerpt">
                    {{ article.excerpt_or_content | strip_html | truncate: 120 }}
                  </p>
                {%- endif -%}
              </div>
            </a>
          {%- else -%}
            <div class="bn-blog__placeholder">
              <div class="bn-blog__placeholder-img"></div>
              <p class="bn-blog__placeholder-text">
                Selecciona un artículo en el editor de temas
              </p>
            </div>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>

  </div>
</div>

{% schema %}
{
  "name": "Blog — Vista previa",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título de la sección",
      "default": "Tu dosis diaria de bienestar"
    },
    {
      "type": "text",
      "id": "see_all_label",
      "label": "Texto del enlace 'Ver todos'",
      "default": "Ver todos los artículos"
    },
    {
      "type": "url",
      "id": "see_all_url",
      "label": "Enlace 'Ver todos'"
    }
  ],
  "blocks": [
    {
      "type": "article_card",
      "name": "Artículo",
      "settings": [
        {
          "type": "article",
          "id": "article",
          "label": "Artículo del blog"
        },
        {
          "type": "image_picker",
          "id": "image_override",
          "label": "Imagen personalizada (opcional)",
          "info": "Sustituye la imagen del artículo si quieres usar otra diferente"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Blog — Vista previa",
      "blocks": [
        { "type": "article_card" },
        { "type": "article_card" },
        { "type": "article_card" }
      ]
    }
  ],
  "max_blocks": 3
}
{% endschema %}
