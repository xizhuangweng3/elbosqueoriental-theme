{%- style -%}
  .bn-brands {
    padding: var(--section-padding-top, 5.2rem) 0 var(--section-padding-bottom, 5.2rem);
  }

  .bn-brands__header {
    text-align: center;
    margin-bottom: 3.6rem;
  }

  .bn-brands__title {
    font-family: var(--font-heading-family);
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 700;
    color: var(--color-foreground);
    margin: 0 0 0.8rem;
    letter-spacing: 0.02em;
  }

  .bn-brands__subtitle {
    font-family: var(--font-body-family);
    font-size: 1.6rem;
    color: var(--color-foreground);
    opacity: 0.65;
    margin: 0;
  }

  .bn-brands__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.6rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media screen and (min-width: 600px) {
    .bn-brands__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (min-width: 750px) {
    .bn-brands__grid {
      grid-template-columns: repeat({{ section.settings.columns_tablet }}, 1fr);
      gap: 2rem;
    }
  }

  @media screen and (min-width: 990px) {
    .bn-brands__grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
      gap: 2.4rem;
    }
  }

  .bn-brands__item {
    list-style: none;
  }

  .bn-brands__card {
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 1.2rem;
    padding: 2.8rem 2rem;
    height: 14rem;
    box-sizing: border-box;
    text-decoration: none;
    transition: transform 0.22s ease, box-shadow 0.22s ease;
    position: relative;
    overflow: hidden;
  }

  {% if section.settings.hover_effects %}
  .bn-brands__card:hover {
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }
  {% endif %}

  .bn-brands__logo-wrap {
    width: 15rem;
    height: 9rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bn-brands__logo-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  /* Fallback name pill when no logo is uploaded */
  .bn-brands__name-fallback {
    font-family: var(--font-heading-family);
    font-size: 1.5rem;
    font-weight: 700;
    color: rgba(0,0,0,0.5);
    text-align: center;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  @media screen and (min-width: 750px) {
    .bn-brands__card {
      height: 16rem;
      padding: 3.2rem 2.4rem;
    }

    .bn-brands__logo-wrap {
      width: 17rem;
      height: 10rem;
    }
  }
{%- endstyle -%}

{%- assign default_colors = '#E8F5E8,#F5E6D3,#F5DDD3,#E3F2FD,#F3E8FF,#FFF9E6,#FAE5E3,#E0F7F4' | split: ',' -%}

<div class="bn-brands color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">

    {%- if section.settings.title != blank or section.settings.subtitle != blank -%}
      <div class="bn-brands__header">
        {%- if section.settings.title != blank -%}
          <h2 class="bn-brands__title">{{ section.settings.title }}</h2>
        {%- endif -%}
        {%- if section.settings.subtitle != blank -%}
          <p class="bn-brands__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="bn-brands__grid" role="list">
        {%- for block in section.blocks -%}
          {%- assign color_index = forloop.index0 | modulo: 8 -%}
          {%- assign bg_color = block.settings.background_color -%}
          {%- if bg_color == blank or bg_color == 'rgba(0,0,0,0)' -%}
            {%- assign bg_color = default_colors[color_index] -%}
          {%- endif -%}

          <li class="bn-brands__item" {{ block.shopify_attributes }}>
            {%- if block.settings.link != blank -%}
              <a
                href="{{ block.settings.link }}"
                class="bn-brands__card"
                style="background-color: {{ bg_color }};"
                aria-label="{{ block.settings.brand_name }}"
              >
            {%- else -%}
              <div
                class="bn-brands__card"
                style="background-color: {{ bg_color }};"
              >
            {%- endif -%}

              <div class="bn-brands__logo-wrap">
                {%- if block.settings.logo != blank -%}
                  {{
                    block.settings.logo
                    | image_url: width: 400
                    | image_tag:
                      loading: 'lazy',
                      widths: '200, 300, 400',
                      alt: block.settings.brand_name
                  }}
                {%- else -%}
                  <span class="bn-brands__name-fallback">{{ block.settings.brand_name }}</span>
                {%- endif -%}
              </div>

            {%- if block.settings.link != blank -%}
              </a>
            {%- else -%}
              </div>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Marcas de confianza",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título de la sección",
      "default": "Marcas de Confianza"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Seleccionadas por nuestros expertos durante más de 40 años"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 3,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "Columnas en escritorio"
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3,
      "label": "Columnas en tablet"
    },
    {
      "type": "checkbox",
      "id": "hover_effects",
      "label": "Efecto hover en las tarjetas",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Esquema de color de la sección",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Marca",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo de la marca"
        },
        {
          "type": "text",
          "id": "brand_name",
          "label": "Nombre de la marca",
          "default": "Marca"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace (colección o página)"
        },
        {
          "type": "color",
          "id": "background_color",
          "label": "Color de fondo de la tarjeta"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marcas de confianza",
      "blocks": [
        { "type": "brand", "settings": { "brand_name": "Solgar" } },
        { "type": "brand", "settings": { "brand_name": "Lamberts" } },
        { "type": "brand", "settings": { "brand_name": "Marnys" } },
        { "type": "brand", "settings": { "brand_name": "Solaray" } },
        { "type": "brand", "settings": { "brand_name": "Soria Natural" } },
        { "type": "brand", "settings": { "brand_name": "Natysal" } },
        { "type": "brand", "settings": { "brand_name": "Equisalud" } },
        { "type": "brand", "settings": { "brand_name": "Sura Vitasan" } }
      ]
    }
  ]
}
{% endschema %}
