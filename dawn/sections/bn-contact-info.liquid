{{ 'bn-contact-info.css' | asset_url | stylesheet_tag }}

<div class="bn-contact color-{{ section.settings.color_scheme }} gradient">
  <div class="bn-contact__inner page-width">

    {%- comment -%} ─── Left: intro + details ─── {%- endcomment -%}
    <div class="bn-contact__details">
      <h1 class="bn-contact__heading">{{ 'pages.contact.heading' | t }}</h1>
      <p class="bn-contact__intro">{{ 'pages.contact.intro' | t }}</p>

      <ul class="bn-contact__list">
        <li class="bn-contact__item">
          <span class="bn-contact__item-icon" aria-hidden="true">📞</span>
          <div>
            <span class="bn-contact__item-label">{{ 'pages.contact.phone_label' | t }}</span>
            <a href="tel:952584736" class="bn-contact__item-value bn-contact__phone">952 584 736</a>
          </div>
        </li>
        <li class="bn-contact__item">
          <span class="bn-contact__item-icon" aria-hidden="true">📍</span>
          <div>
            <span class="bn-contact__item-label">{{ 'pages.contact.location_label' | t }}</span>
            <span class="bn-contact__item-value">{{ 'pages.contact.location_value' | t }}</span>
          </div>
        </li>
        <li class="bn-contact__item">
          <span class="bn-contact__item-icon" aria-hidden="true">🕐</span>
          <div>
            <span class="bn-contact__item-label">{{ 'pages.contact.hours_label' | t }}</span>
            <span class="bn-contact__item-value">{{ 'pages.contact.hours_value' | t }}</span>
          </div>
        </li>
      </ul>
    </div>

    {%- comment -%} ─── Right: contact form ─── {%- endcomment -%}
    <div class="bn-contact__form-wrapper">
      {%- form 'contact', id: 'BNContactForm', class: 'bn-contact__form' -%}
        {%- if form.posted_successfully? -%}
          <div class="bn-contact__success" role="status">
            {{ 'pages.contact.success_message' | t }}
          </div>
        {%- elsif form.errors -%}
          <div class="bn-contact__errors" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="bn-contact__field">
          <label for="ContactFormName" class="bn-contact__label">
            {{ 'pages.contact.name_label' | t }}
          </label>
          <input
            type="text"
            id="ContactFormName"
            name="contact[name]"
            autocomplete="name"
            value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
            class="bn-contact__input field__input"
            required
          >
        </div>

        <div class="bn-contact__field">
          <label for="ContactFormEmail" class="bn-contact__label">
            {{ 'pages.contact.email_label' | t }}
          </label>
          <input
            type="email"
            id="ContactFormEmail"
            name="contact[email]"
            autocomplete="email"
            value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
            class="bn-contact__input field__input"
            required
          >
        </div>

        <div class="bn-contact__field">
          <label for="ContactFormSubject" class="bn-contact__label">
            {{ 'pages.contact.subject_label' | t }}
          </label>
          <input
            type="text"
            id="ContactFormSubject"
            name="contact[subject]"
            class="bn-contact__input field__input"
          >
        </div>

        <div class="bn-contact__field">
          <label for="ContactFormMessage" class="bn-contact__label">
            {{ 'pages.contact.message_label' | t }}
          </label>
          <textarea
            id="ContactFormMessage"
            name="contact[body]"
            rows="6"
            class="bn-contact__textarea field__input"
            required
          ></textarea>
        </div>

        <button type="submit" class="button button--primary bn-contact__submit">
          {{ 'pages.contact.submit_label' | t }}
        </button>
      {%- endform -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Contacto — Info y Formulario",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        { "value": "scheme-1", "label": "Scheme 1" },
        { "value": "scheme-2", "label": "Scheme 2" }
      ],
      "default": "scheme-1",
      "label": "Esquema de color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding superior",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding inferior",
      "default": 52
    }
  ],
  "presets": [
    {
      "name": "Contacto — Info y Formulario"
    }
  ]
}
{% endschema %}
