{{ 'bn-contact-info.css' | asset_url | stylesheet_tag }}

<div class="bn-contact color-{{ section.settings.color_scheme }} gradient">
  <div class="bn-contact__inner page-width">

    {%- comment -%} ─── Left: contact details ─── {%- endcomment -%}
    <div class="bn-contact__details">

      {%- if section.settings.heading != blank -%}
        <h1 class="bn-contact__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.intro != blank -%}
        <p class="bn-contact__intro">{{ section.settings.intro }}</p>
      {%- endif -%}

      <ul class="bn-contact__list">

        {%- comment -%} Phone {%- endcomment -%}
        {%- if section.settings.phone != blank -%}
          <li class="bn-contact__item">
            <span class="bn-contact__item-icon" aria-hidden="true">📞</span>
            <div>
              <span class="bn-contact__item-label">{{ section.settings.phone_label | default: 'Teléfono' }}</span>
              <a href="tel:{{ section.settings.phone | remove: ' ' }}" class="bn-contact__item-value bn-contact__phone">
                {{ section.settings.phone }}
              </a>
            </div>
          </li>
        {%- endif -%}

        {%- comment -%} Mobile {%- endcomment -%}
        {%- if section.settings.mobile != blank -%}
          <li class="bn-contact__item">
            <span class="bn-contact__item-icon" aria-hidden="true">📱</span>
            <div>
              <span class="bn-contact__item-label">{{ section.settings.mobile_label | default: 'Móvil' }}</span>
              <a href="tel:{{ section.settings.mobile | remove: ' ' }}" class="bn-contact__item-value bn-contact__phone">
                {{ section.settings.mobile }}
              </a>
            </div>
          </li>
        {%- endif -%}

        {%- comment -%} WhatsApp {%- endcomment -%}
        {%- if section.settings.whatsapp != blank -%}
          {%- assign wa_number = section.settings.whatsapp | remove: ' ' -%}
          <li class="bn-contact__item">
            <span class="bn-contact__item-icon bn-contact__item-icon--whatsapp" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </span>
            <div>
              <span class="bn-contact__item-label">{{ section.settings.whatsapp_label | default: 'WhatsApp' }}</span>
              <a
                href="https://wa.me/34{{ wa_number }}"
                class="bn-contact__item-value bn-contact__whatsapp"
                target="_blank"
                rel="noopener noreferrer"
              >
                {{ section.settings.whatsapp }}
              </a>
            </div>
          </li>
        {%- endif -%}

        {%- comment -%} Address {%- endcomment -%}
        {%- if section.settings.address != blank -%}
          <li class="bn-contact__item">
            <span class="bn-contact__item-icon" aria-hidden="true">📍</span>
            <div>
              <span class="bn-contact__item-label">{{ section.settings.address_label | default: 'Ubicación' }}</span>
              <span class="bn-contact__item-value">{{ section.settings.address }}</span>
            </div>
          </li>
        {%- endif -%}

        {%- comment -%} Hours {%- endcomment -%}
        <li class="bn-contact__item bn-contact__item--hours">
          <span class="bn-contact__item-icon" aria-hidden="true">🕐</span>
          <div>
            <span class="bn-contact__item-label">{{ section.settings.hours_label | default: 'Horario' }}</span>
            {%- assign days   = 'Lunes,Martes,Miércoles,Jueves,Viernes,Sábado,Domingo' | split: ',' -%}
            {%- assign h_keys = 'hours_mon,hours_tue,hours_wed,hours_thu,hours_fri,hours_sat,hours_sun' | split: ',' -%}
            <dl class="bn-contact__hours">
              {%- for day in days -%}
                {%- assign h_val = section.settings[h_keys[forloop.index0]] | default: '—' -%}
                <div class="bn-contact__hours-row{% if h_val == 'Cerrado' %} bn-contact__hours-row--closed{% endif %}">
                  <dt class="bn-contact__day">{{ day }}</dt>
                  <dd class="bn-contact__time">{{ h_val }}</dd>
                </div>
              {%- endfor -%}
            </dl>
          </div>
        </li>

      </ul>
    </div>

    {%- comment -%} ─── Right: contact form ─── {%- endcomment -%}
    <div class="bn-contact__form-wrapper">
      {%- form 'contact', id: 'BNContactForm', class: 'bn-contact__form' -%}
        {%- if form.posted_successfully? -%}
          <div class="bn-contact__success" role="status">
            {{ section.settings.success_message | default: '¡Mensaje enviado! Te responderemos lo antes posible.' }}
          </div>
        {%- elsif form.errors -%}
          <div class="bn-contact__errors" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="bn-contact__field">
          <label for="ContactFormName" class="bn-contact__label">
            {{ section.settings.label_name | default: 'Nombre' }}
          </label>
          <input
            type="text"
            id="ContactFormName"
            name="contact[name]"
            autocomplete="name"
            value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
            class="bn-contact__input"
            placeholder="{{ section.settings.placeholder_name | default: 'Tu nombre completo' }}"
            required
          >
        </div>

        <div class="bn-contact__field">
          <label for="ContactFormEmail" class="bn-contact__label">
            {{ section.settings.label_email | default: 'Correo electrónico' }}
          </label>
          <input
            type="email"
            id="ContactFormEmail"
            name="contact[email]"
            autocomplete="email"
            value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
            class="bn-contact__input"
            placeholder="{{ section.settings.placeholder_email | default: 'tucorreo@ejemplo.com' }}"
            required
          >
        </div>

        <div class="bn-contact__field">
          <label for="ContactFormSubject" class="bn-contact__label">
            {{ section.settings.label_subject | default: 'Asunto' }}
          </label>
          <input
            type="text"
            id="ContactFormSubject"
            name="contact[subject]"
            class="bn-contact__input"
            placeholder="{{ section.settings.placeholder_subject | default: '¿En qué podemos ayudarte?' }}"
          >
        </div>

        <div class="bn-contact__field">
          <label for="ContactFormMessage" class="bn-contact__label">
            {{ section.settings.label_message | default: 'Mensaje' }}
          </label>
          <textarea
            id="ContactFormMessage"
            name="contact[body]"
            rows="6"
            class="bn-contact__textarea"
            placeholder="{{ section.settings.placeholder_message | default: 'Escribe tu mensaje aquí...' }}"
            required
          ></textarea>
        </div>

        <button type="submit" class="button button--primary bn-contact__submit">
          {{ section.settings.submit_label | default: 'Enviar mensaje' }}
        </button>
      {%- endform -%}
    </div>

  </div>
</div>

