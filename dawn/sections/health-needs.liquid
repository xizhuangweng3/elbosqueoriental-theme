{%- comment -%}
  health-needs.liquid
  "Compra según tu necesidad" — horizontal scroll of tall category cards + optional quiz CTA.
  Figma spec: cards 129×213px, image with bottom gradient blur overlay, white label.
{%- endcomment -%}

<style>
  /* ── Section wrapper ── */
  #shopify-section-{{ section.id }} {
    background-color: #F9ECDD;
    padding: 56px 0;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      padding: 40px 0;
    }
  }

  /* ── Container ── */
  #shopify-section-{{ section.id }} .hn-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 30px;
  }

  /* ── Header ── */
  #shopify-section-{{ section.id }} .hn-header {
    margin-bottom: 32px;
  }

  #shopify-section-{{ section.id }} .hn-heading {
    font-family: var(--font-heading-family);
    font-size: 3.6rem;
    font-weight: 700;
    color: #143007;
    margin: 0 0 0.8rem;
    line-height: 84%;
    letter-spacing: -0.02em;
  }

  #shopify-section-{{ section.id }} .hn-subheading {
    font-family: var(--font-body-family);
    font-size: 1.6rem;
    color: #143007;
    margin: 0;
    opacity: 0.75;
  }

  /* ── Cards track — horizontal scroll ── */
  #shopify-section-{{ section.id }} .hn-track {
    display: flex;
    flex-direction: row;
    gap: 20px;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 4px;
    list-style: none;
    margin: 0;
    padding-left: 0;
  }

  #shopify-section-{{ section.id }} .hn-track::-webkit-scrollbar {
    display: none;
  }

  /* ── List items are the flex children — must have fixed width ── */
  #shopify-section-{{ section.id }} .hn-track > li {
    flex: 0 0 160px;
    height: 240px;
    list-style: none;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .hn-track > li {
      flex: 0 0 calc((100% - 5 * 20px) / 6);
      height: 213px;
    }
  }

  /* ── Individual card ── */
  #shopify-section-{{ section.id }} .hn-card {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    display: block;
    background: #143007;
    transition: transform 0.3s ease;
  }

  #shopify-section-{{ section.id }} .hn-card:hover {
    transform: scale(1.03);
  }

  /* Blur image on hover so label reads more clearly */
  #shopify-section-{{ section.id }} .hn-card:hover .hn-card__img {
    filter: blur(3px);
    transform: scale(1.08);
    transition: filter 0.35s ease, transform 0.35s ease;
  }

  #shopify-section-{{ section.id }} .hn-card__img {
    transition: filter 0.35s ease, transform 0.35s ease;
  }

  /* Darken overlay on hover for extra contrast */
  #shopify-section-{{ section.id }} .hn-card:hover .hn-card__overlay {
    background: rgba(20, 48, 7, 0.65);
    transition: background 0.35s ease;
  }

  #shopify-section-{{ section.id }} .hn-card__overlay {
    transition: background 0.35s ease;
  }

  /* ── Card image ── */
  #shopify-section-{{ section.id }} .hn-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* ── Bottom gradient blur overlay ── */
  #shopify-section-{{ section.id }} .hn-card__overlay {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 45%;
    background: rgba(61, 61, 61, 0.55);
    filter: blur(3px);
    pointer-events: none;
  }

  /* ── Label ── */
  #shopify-section-{{ section.id }} .hn-card__label {
    position: absolute;
    bottom: 12px;
    left: 0;
    right: 0;
    text-align: center;
    font-family: var(--font-heading-family);
    font-size: 1.8rem;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.2;
    letter-spacing: -0.02em;
    padding: 0 8px;
    z-index: 2;
    text-shadow: 0 1px 4px rgba(0,0,0,0.4);
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .hn-card__label {
      font-size: 1.5rem;
    }
  }

  /* ── Quiz CTA ── */
  #shopify-section-{{ section.id }} .hn-quiz {
    margin-top: 48px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .hn-quiz__heading {
    font-family: var(--font-heading-family);
    font-size: 2.4rem;
    font-weight: 700;
    color: #143007;
    letter-spacing: -0.02em;
    line-height: 84%;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .hn-quiz__body {
    font-family: var(--font-body-family);
    font-size: 1.6rem;
    color: #143007;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .hn-quiz__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 20px;
    height: 44px;
    background: #D60036;
    color: #FEF9F3;
    font-family: var(--font-body-family);
    font-size: 1.6rem;
    font-weight: 400;
    letter-spacing: 0.01em;
    text-decoration: none;
    border-radius: 2px;
    box-shadow: 0px 2px 4px rgba(0, 0, 0, 0.25);
    transition: opacity 0.2s ease;
  }

  #shopify-section-{{ section.id }} .hn-quiz__btn:hover {
    opacity: 0.88;
  }
</style>

<div id="shopify-section-hn-{{ section.id }}">
  <div class="hn-inner">

    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="hn-header">
        {%- if section.settings.heading != blank -%}
          <h2 class="hn-heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="hn-subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="hn-track" role="list">
        {%- for block in section.blocks -%}
          {%- assign card_url = block.settings.collection.url | default: '#' -%}
          <li {{ block.shopify_attributes }}>
            <a
              href="{{ card_url }}"
              class="hn-card"
              aria-label="{{ block.settings.title | escape }}"
            >
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 400
                  | image_tag:
                    loading: 'lazy',
                    widths: '160, 260, 400',
                    alt: block.settings.title,
                    class: 'hn-card__img'
                }}
              {%- else -%}
                <div class="hn-card__img" style="background: linear-gradient(160deg, #c8dfc8 0%, #8ab88a 100%);"></div>
              {%- endif -%}
              <div class="hn-card__overlay"></div>
              {%- if block.settings.title != blank -%}
                <span class="hn-card__label">{{ block.settings.title }}</span>
              {%- endif -%}
            </a>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

    {%- if section.settings.quiz_heading != blank -%}
      <div class="hn-quiz">
        <h3 class="hn-quiz__heading">{{ section.settings.quiz_heading }}</h3>
        {%- if section.settings.quiz_body != blank -%}
          <p class="hn-quiz__body">{{ section.settings.quiz_body }}</p>
        {%- endif -%}
        {%- if section.settings.quiz_btn_label != blank -%}
          <a href="{{ section.settings.quiz_btn_link | default: '#' }}" class="hn-quiz__btn">
            {{ section.settings.quiz_btn_label }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Compra por necesidad",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Encabezado"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Compra según tu necesidad"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subtítulo (opcional)",
      "default": "Encuentra los suplementos ideales para tu objetivo de salud"
    },
    {
      "type": "header",
      "content": "Quiz CTA (opcional)"
    },
    {
      "type": "text",
      "id": "quiz_heading",
      "label": "Título del quiz",
      "default": "¿No sabes por dónde empezar?"
    },
    {
      "type": "text",
      "id": "quiz_body",
      "label": "Descripción del quiz",
      "default": "Responde este breve cuestionario y te ayudamos a encontrar lo que necesitas"
    },
    {
      "type": "text",
      "id": "quiz_btn_label",
      "label": "Texto del botón",
      "default": "Hacer el test"
    },
    {
      "type": "url",
      "id": "quiz_btn_link",
      "label": "Enlace del botón"
    }
  ],
  "blocks": [
    {
      "type": "health_category",
      "name": "Categoría",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen de la categoría"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Nombre de la categoría",
          "default": "Categoría"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Colección vinculada"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Compra por necesidad",
      "blocks": [
        { "type": "health_category", "settings": { "title": "Vitaminas y Minerales" } },
        { "type": "health_category", "settings": { "title": "Digestión y Microbiota" } },
        { "type": "health_category", "settings": { "title": "Colesterol y Corazón" } },
        { "type": "health_category", "settings": { "title": "Energía, Estrés y Sueño" } },
        { "type": "health_category", "settings": { "title": "Memoria y Sistema Nervioso" } },
        { "type": "health_category", "settings": { "title": "Medicina Tradicional China" } }
      ]
    }
  ],
  "max_blocks": 12
}
{% endschema %}
