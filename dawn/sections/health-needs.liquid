{%- comment -%}
  health-needs.liquid
  "Compra según tu necesidad" — image-card grid linking to health-category collections.
  Inspired by Solgar's "Shop by your health needs" section.
{%- endcomment -%}

<style>
  #shopify-section-{{ section.id }} {
    padding: 60px 0;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      padding: 40px 0;
    }
  }

  /* ── Inner container ── */
  #shopify-section-{{ section.id }} .hn-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .hn-inner {
      padding: 0 16px;
    }
  }

  /* ── Header ── */
  #shopify-section-{{ section.id }} .hn-header {
    text-align: center;
    margin-bottom: 32px;
  }

  #shopify-section-{{ section.id }} .hn-heading {
    font-family: var(--font-heading-family);
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 700;
    color: rgb(var(--color-foreground));
    margin: 0 0 0.8rem;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .hn-subheading {
    font-family: var(--font-body-family);
    font-size: clamp(1.5rem, 2vw, 1.7rem);
    color: rgb(var(--color-foreground) / 0.65);
    margin: 0;
    line-height: 1.6;
  }

  /* ── Grid ── */
  #shopify-section-{{ section.id }} .hn-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .hn-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 480px) {
    #shopify-section-{{ section.id }} .hn-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ── Card ── */
  #shopify-section-{{ section.id }} .hn-card {
    display: block;
    position: relative;
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    outline-offset: 3px;
  }

  #shopify-section-{{ section.id }} .hn-card:focus-visible {
    outline: 2px solid rgb(var(--color-foreground));
  }

  /* ── Image wrapper — fixed 3:2 ratio ── */
  #shopify-section-{{ section.id }} .hn-card__media {
    position: relative;
    width: 100%;
    padding-top: 66.666%;
    overflow: hidden;
    background: rgb(var(--color-foreground) / 0.06);
  }

  #shopify-section-{{ section.id }} .hn-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.45s ease;
  }

  #shopify-section-{{ section.id }} .hn-card__img--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .hn-card__img--placeholder svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Hover zoom */
  #shopify-section-{{ section.id }} .hn-card:hover .hn-card__img {
    transform: scale(1.04);
  }

  /* ── Gradient overlay — ensures label is always readable ── */
  #shopify-section-{{ section.id }} .hn-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.62) 0%,
      rgba(0, 0, 0, 0.18) 45%,
      rgba(0, 0, 0, 0) 100%
    );
    pointer-events: none;
  }

  /* ── Category label ── */
  #shopify-section-{{ section.id }} .hn-card__label {
    position: absolute;
    bottom: 16px;
    left: 20px;
    right: 20px;
    font-family: var(--font-heading-family);
    font-size: clamp(1.5rem, 2vw, 1.8rem);
    font-weight: 700;
    color: #ffffff;
    line-height: 1.25;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.3);
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .hn-card__label {
      font-size: 1.5rem;
      bottom: 12px;
      left: 14px;
      right: 14px;
    }
  }
</style>

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="hn-inner">

    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="hn-header">
        {%- if section.settings.heading != blank -%}
          <h2 class="hn-heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="hn-subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="hn-grid" role="list">
        {%- for block in section.blocks -%}
          {%- assign card_url = block.settings.collection.url | default: '#' -%}

          <li {{ block.shopify_attributes }}>
            <a
              href="{{ card_url }}"
              class="hn-card"
              aria-label="{{ block.settings.title | escape }}"
            >
              <div class="hn-card__media">
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 900
                    | image_tag:
                      loading: 'lazy',
                      widths: '480, 600, 750, 900',
                      alt: block.settings.title,
                      class: 'hn-card__img'
                  }}
                {%- else -%}
                  <div class="hn-card__img hn-card__img--placeholder">
                    {{ 'lifestyle-1' | placeholder_svg_tag }}
                  </div>
                {%- endif -%}
                <div class="hn-card__overlay"></div>
                {%- if block.settings.title != blank -%}
                  <span class="hn-card__label">{{ block.settings.title }}</span>
                {%- endif -%}
              </div>
            </a>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Compra por necesidad",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título de la sección",
      "default": "Compra según tu necesidad"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subtítulo (opcional)",
      "default": "Encuentra los suplementos ideales para tu objetivo de salud"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Esquema de color",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "health_category",
      "name": "Categoría",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen de la categoría"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Nombre de la categoría",
          "default": "Categoría"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Colección vinculada"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Compra por necesidad",
      "blocks": [
        {
          "type": "health_category",
          "settings": { "title": "Vitaminas y Minerales" }
        },
        {
          "type": "health_category",
          "settings": { "title": "Digestión y Microbiota" }
        },
        {
          "type": "health_category",
          "settings": { "title": "Colesterol y Corazón" }
        },
        {
          "type": "health_category",
          "settings": { "title": "Energía, Estrés y Sueño" }
        },
        {
          "type": "health_category",
          "settings": { "title": "Memoria y Sistema Nervioso" }
        },
        {
          "type": "health_category",
          "settings": { "title": "Medicina Tradicional China" }
        }
      ]
    }
  ],
  "max_blocks": 12
}
{% endschema %}
