{
  "sections": {
    "image_banner": {
      "type": "bn-image-banner",
      "blocks": {
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "Cuatro décadas cuidando tu salud",
            "heading_size": "h0"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "Suplementos y vitaminas de confianza seleccionados con el mismo cuidado que elegiríamos para nuestra propia familia.",
            "text_style": "body"
          }
        },
        "button": {
          "type": "buttons",
          "settings": {
            "button_label_1": "Ver Productos",
            "button_link_1": "shopify://collections/all",
            "button_style_secondary_1": false,
            "button_label_2": "Nuestra Historia",
            "button_link_2": "shopify://pages/nosotros",
            "button_style_secondary_2": true
          }
        }
      },
      "block_order": [
        "heading",
        "text",
        "button"
      ],
      "settings": {
        "image_overlay_opacity": 40,
        "image_height": "large",
        "desktop_content_position": "bottom-center",
        "show_text_box": false,
        "desktop_content_alignment": "center",
        "color_scheme": "scheme-3",
        "mobile_content_alignment": "center",
        "stack_images_on_mobile": false,
        "show_text_below": false
      }
    },
    "featured_collection": {
      "type": "featured-collection",
      "settings": {
        "title": "Nuestros Productos",
        "heading_size": "h2",
        "collection": "all",
        "products_to_show": 8,
        "columns_desktop": 4,
        "color_scheme": "scheme-1",
        "show_view_all": true,
        "swipe_on_mobile": true,
        "image_ratio": "adapt",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": false,
        "columns_mobile": "2",
        "padding_top": 36,
        "padding_bottom": 36
      }
    },
    "brand_story": {
      "type": "rich-text",
      "blocks": {
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "Cuatro décadas de dedicación, una sola familia",
            "heading_size": "h1"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "<p>Todo empezó con una convicción sencilla: el verdadero bienestar nace cuando la sabiduría ancestral se une a la ciencia moderna. Lo que comenzó como un pequeño proyecto familiar en Fuengirola se ha convertido en un lugar de referencia para quienes buscan cuidarse de verdad. Hemos visto crecer a hijos y llegar a nietos. Somos parte de la historia de salud de nuestra comunidad.<\/p>"
          }
        },
        "button": {
          "type": "button",
          "settings": {
            "button_label": "Conoce Nuestra Historia",
            "button_link": "shopify://pages/nosotros",
            "button_style_secondary": true
          }
        }
      },
      "block_order": [
        "heading",
        "text",
        "button"
      ],
      "settings": {
        "color_scheme": "scheme-2",
        "full_width": true,
        "padding_top": 52,
        "padding_bottom": 52
      }
    },
    "trust_bar": {
      "type": "multicolumn",
      "blocks": {
        "column1": {
          "type": "column",
          "settings": {
            "title": "Más de 40 años de experiencia",
            "text": "<p>Una familia dedicada a la salud natural desde 1984.<\/p>",
            "link_label": "",
            "link": ""
          }
        },
        "column2": {
          "type": "column",
          "settings": {
            "title": "Envío gratis a partir de €50",
            "text": "<p>Enviamos a España y toda Europa con total garantía.<\/p>",
            "link_label": "",
            "link": ""
          }
        },
        "column3": {
          "type": "column",
          "settings": {
            "title": "Productos seleccionados a mano",
            "text": "<p>Cada producto elegido con el mismo cuidado que elegiríamos para nuestra familia.<\/p>",
            "link_label": "",
            "link": ""
          }
        },
        "column4": {
          "type": "column",
          "settings": {
            "title": "Consejo experto: 952 584 736",
            "text": "<p>Llámanos — siempre hay alguien dispuesto a ayudarte.<\/p>",
            "link_label": "",
            "link": ""
          }
        }
      },
      "block_order": [
        "column1",
        "column2",
        "column3",
        "column4"
      ],
      "settings": {
        "title": "",
        "heading_size": "h1",
        "image_width": "third",
        "image_ratio": "adapt",
        "columns_desktop": 4,
        "column_alignment": "center",
        "background_style": "none",
        "button_label": "",
        "button_link": "",
        "swipe_on_mobile": true,
        "color_scheme": "scheme-1",
        "columns_mobile": "1",
        "padding_top": 36,
        "padding_bottom": 36
      }
    },
    "brand_carousel": {
      "type": "bn-brand-carousel",
      "blocks": {
        "solgar":        { "type": "brand", "settings": { "brand_name": "Solgar",        "background_color": "#E8F5E8" } },
        "lamberts":      { "type": "brand", "settings": { "brand_name": "Lamberts",      "background_color": "#F4E4D3" } },
        "marnys":        { "type": "brand", "settings": { "brand_name": "Marnys",        "background_color": "#FFE4E9" } },
        "solaray":       { "type": "brand", "settings": { "brand_name": "Solaray",       "background_color": "#E3F2FD" } },
        "soria_natural": { "type": "brand", "settings": { "brand_name": "Soria Natural", "background_color": "#F0E6FF" } },
        "natysal":       { "type": "brand", "settings": { "brand_name": "Natysal",       "background_color": "#FFF9E6" } },
        "equisalud":     { "type": "brand", "settings": { "brand_name": "Equisalud",     "background_color": "#FFE8DC" } },
        "sura_vitasan":  { "type": "brand", "settings": { "brand_name": "Sura Vitasan",  "background_color": "#D4F4E8" } }
      },
      "block_order": [
        "solgar", "lamberts", "marnys", "solaray",
        "soria_natural", "natysal", "equisalud", "sura_vitasan"
      ],
      "settings": {
        "title": "Nuestras Marcas de Confianza",
        "btn_label": "Ver todas",
        "slides_desktop": 6,
        "slides_tablet": 4,
        "slides_mobile": 2,
        "hover_effects": true,
        "color_scheme": "scheme-1",
        "padding_top": 32,
        "padding_bottom": 32
      }
    }
  },
  "order": [
    "image_banner",
    "featured_collection",
    "brand_story",
    "trust_bar",
    "brand_carousel"
  ]
}
